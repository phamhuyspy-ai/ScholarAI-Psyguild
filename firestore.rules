rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (optional, enum: ['user', 'admin'])
    //   - subscription: string (optional, enum: ['free', 'monthly', 'yearly'])
    //   - subscriptionExpiry: timestamp (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: usage
    // Document ID: {userId}_{date} (e.g. 123_2023-10-27)
    // Fields:
    //   - userId: string (required)
    //   - date: string (required)
    //   - count: number (required)
    //   - lastUpdated: timestamp (required)
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - id: string (required)
    //   - userId: string (required, immutable)
    //   - title: string (required)
    //   - topic: string (optional)
    //   - design: string (optional)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // Collection: analyses
    // Document ID: {analysisId}
    // Fields:
    //   - id: string (required)
    //   - userId: string (required, immutable)
    //   - type: string (required, enum: ['duplication', 'plagiarism', 'video'])
    //   - input: string (required)
    //   - result: string (required)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "chatgptpsy7304@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'subscription', 'subscriptionExpiry', 'createdAt']) &&
             isValidString('uid', 1, 128) &&
             isValidString('email', 3, 256) &&
             isValidOptionalString('displayName', 0, 100) &&
             isValidOptionalString('photoURL', 0, 2048) &&
             (!( 'role' in request.resource.data ) || request.resource.data.role in ['user', 'admin']) &&
             (!( 'subscription' in request.resource.data ) || request.resource.data.subscription in ['free', 'monthly', 'yearly']) &&
             (!( 'subscriptionExpiry' in request.resource.data ) || request.resource.data.subscriptionExpiry is timestamp) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidUsage() {
      return hasOnlyAllowedFields(['userId', 'date', 'count', 'lastUpdated']) &&
             isValidString('userId', 1, 128) &&
             isValidString('date', 10, 10) &&
             request.resource.data.count is number &&
             request.resource.data.count >= 0 &&
             request.resource.data.lastUpdated is timestamp;
    }

    function isValidProject() {
      return hasOnlyAllowedFields(['id', 'userId', 'title', 'topic', 'design', 'createdAt', 'updatedAt']) &&
             isValidString('id', 1, 128) &&
             isValidString('userId', 1, 128) &&
             isValidString('title', 1, 256) &&
             isValidOptionalString('topic', 0, 1000) &&
             isValidOptionalString('design', 0, 100000) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp;
    }

    function isValidAnalysis() {
      return hasOnlyAllowedFields(['id', 'userId', 'type', 'input', 'result', 'createdAt']) &&
             isValidString('id', 1, 128) &&
             isValidString('userId', 1, 128) &&
             request.resource.data.type in ['duplication', 'plagiarism', 'video'] &&
             isValidString('input', 1, 100000) &&
             isValidString('result', 1, 100000) &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged() && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin()) &&
                    (!('subscription' in request.resource.data) || request.resource.data.subscription == 'free' || isAdmin());
      allow update: if (isOwner(userId) && isValidUser() && uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt &&
                    (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) &&
                    (!('subscription' in request.resource.data) || request.resource.data.subscription == resource.data.subscription) &&
                    (!('subscriptionExpiry' in request.resource.data) || request.resource.data.subscriptionExpiry == resource.data.subscriptionExpiry)) || isAdmin();
    }

    match /usage/{usageId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidUsage();
      allow update: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidUsage() &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.date == resource.data.date;
    }

    match /projects/{projectId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidProject();
      allow update: if isDocOwner() && isValidProject() &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /analyses/{analysisId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidAnalysis();
      allow update: if false; // Analyses are immutable
      allow delete: if isDocOwner();
    }
  }
}
